<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
    <OutputType>Library</OutputType>
    <NoWarn>$(NoWarn);FS0988</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="RawInputTests.fs" />
    <Compile Include="ParsedInputTests.fs" />
    <Compile Include="InputParseTests.fs" />
    <Compile Include="SchemaDiagnosticsRenderingTests.fs" />
    <Compile Include="SchemaConstraintCheckTests.fs" />
    <Compile Include="SchemaRefinedValueCheckTests.fs" />
    <Compile Include="SchemaVerticalSliceProofTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Unquote" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Axial.Validation.Schema\Axial.Validation.Schema.fsproj" />
  </ItemGroup>

</Project>
