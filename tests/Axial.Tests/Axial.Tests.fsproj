<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
    <OutputType>Library</OutputType>
    <NoWarn>$(NoWarn);FS0988</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="TestSupport.fs" />
    <Compile Include="CoreServiceTests.fs" />
    <Compile Include="UnifiedServiceTests.fs" />
    <Compile Include="DependencyInjectionIntegrationTests.fs" />
    <Compile Include="FileSystemServiceTests.fs" />
    <Compile Include="HostingTests.fs" />
    <Compile Include="RuntimeFoundationTests.fs" />
    <Compile Include="TelemetryTests.fs" />
    <Compile Include="ServiceRuntimePatternTests.fs" />
    <Compile Include="ApiShapeTests.fs" />
    <Compile Include="FlowRuntimeMetadataTests.fs" />
    <Compile Include="RuntimeSemanticsTests.fs" />
    <Compile Include="WorkflowBasicTests.fs" />
    <Compile Include="ExecutionTests.fs" />
    <Compile Include="WorkflowConcurrencyTests.fs" />
    <Compile Include="WorkflowParallelTests.fs" />
    <Compile Include="WorkflowErrorTests.fs" />
    <Compile Include="WorkflowSchedulingTests.fs" />
    <Compile Include="WorkflowResourceTests.fs" />
    <Compile Include="WorkflowStateTests.fs" />
    <Compile Include="WorkflowStreamTests.fs" />
    <Compile Include="RefinedTests.fs" />
    <Compile Include="ValidationTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="8.0.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Unquote" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Axial\Axial.fsproj" />
    <ProjectReference Include="..\..\src\Axial.Flow.PlatformService\Axial.Flow.PlatformService.fsproj" />
    <ProjectReference Include="..\..\src\Axial.Flow.Console\Axial.Flow.Console.fsproj" />
    <ProjectReference Include="..\..\src\Axial.Flow.FileSystem\Axial.Flow.FileSystem.fsproj" />
    <ProjectReference Include="..\..\src\Axial.Flow.Http\Axial.Flow.Http.fsproj" />
    <ProjectReference Include="..\..\src\Axial.Flow.Process\Axial.Flow.Process.fsproj" />
    <ProjectReference Include="..\..\src\Axial.Flow.Hosting\Axial.Flow.Hosting.fsproj" />
    <ProjectReference Include="..\..\src\Axial.Flow.Telemetry\Axial.Flow.Telemetry.fsproj" />
  </ItemGroup>

</Project>
