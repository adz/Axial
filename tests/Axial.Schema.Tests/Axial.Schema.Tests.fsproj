<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
    <OutputType>Library</OutputType>
    <NoWarn>$(NoWarn);FS0988</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="SchemaConstraintInspectionTests.fs" />
    <Compile Include="SchemaConstructorGetterAlignmentTests.fs" />
    <Compile Include="SchemaCompiledRecordPlanProofTests.fs" />
    <Compile Include="SchemaRefinedValueTests.fs" />
    <Compile Include="SchemaFormatTests.fs" />
    <Compile Include="SchemaDescriptionTests.fs" />
    <Compile Include="SchemaNestedValueTests.fs" />
    <Compile Include="SchemaManyValueTests.fs" />
    <Compile Include="SchemaMapValueTests.fs" />
    <Compile Include="SchemaUnionValueTests.fs" />
    <Compile Include="SchemaOptionalValueTests.fs" />
    <Compile Include="SchemaInterpreterPrototypeTests.fs" />
    <Compile Include="SchemaGenerationTargetProofTests.fs" />
    <Compile Include="SchemaDslTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Unquote" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Axial.Schema\Axial.Schema.fsproj" />
  </ItemGroup>

</Project>
