    <Compile Include="SchemaRefinedValueTests.fs" />
    <Compile Include="SchemaFormatTests.fs" />
    <Compile Include="SchemaDescriptionTests.fs" />
    <Compile Include="SchemaNestedValueTests.fs" />
    <Compile Include="SchemaManyValueTests.fs" />
    <Compile Include="SchemaMapValueTests.fs" />
    <Compile Include="SchemaEnumValueTests.fs" />
    <Compile Include="SchemaUnionValueTests.fs" />
    <Compile Include="SchemaUnionInlineValueTests.fs" />
    <Compile Include="SchemaOptionalValueTests.fs" />
    <Compile Include="SchemaInterpreterPrototypeTests.fs" />
    <Compile Include="SchemaGenerationTargetProofTests.fs" />
    <Compile Include="SchemaDslTests.fs" />
    <Compile Include="RawInputTests.fs" />
    <Compile Include="ParsedInputTests.fs" />
    <Compile Include="SchemaErrorTests.fs" />
    <Compile Include="InputParseTests.fs" />
    <Compile Include="NestedSchemaParseTests.fs" />
    <Compile Include="ManySchemaParseTests.fs" />
    <Compile Include="MapSchemaParseTests.fs" />
    <Compile Include="EnumSchemaParseTests.fs" />
    <Compile Include="UnionSchemaParseTests.fs" />
    <Compile Include="UnionInlineSchemaParseTests.fs" />
    <Compile Include="OptionalSchemaParseTests.fs" />
    <Compile Include="SchemaValidationTests.fs" />
    <Compile Include="ContextRulesTests.fs" />
    <Compile Include="ContractTests.fs" />
    <Compile Include="RecursiveSchemaTests.fs" />
    <Compile Include="SchemaDiagnosticsRenderingTests.fs" />
    <Compile Include="SchemaConstraintCheckTests.fs" />
    <Compile Include="SchemaRefinedValueCheckTests.fs" />
    <Compile Include="RefinedCatalogSchemaTests.fs" />
    <Compile Include="SchemaVerticalSliceProofTests.fs" />
    <Compile Include="contracts/geo.g.fs" />
    <Compile Include="contracts/category.g.fs" />
    <Compile Include="contracts/signup.g.fs" />
    <Compile Include="contracts/payment.g.fs" />
    <Compile Include="GeneratedContractTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Unquote" Version="7.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Axial.Schema\Axial.Schema.fsproj" />
    <ProjectReference Include="..\..\src\Axial.Codec\Axial.Codec.fsproj" />
  </ItemGroup>

</Project>
