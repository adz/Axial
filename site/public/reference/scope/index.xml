    <item>
      <title>Scope</title>
      <link>http://localhost:3000/reference/scope/t-scope/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:3000/reference/scope/t-scope/</guid>
      <description>&lt;p&gt;Owns finalizers for resources acquired during provisioning or runtime execution.&lt;/p&gt;&#xA;&lt;h2 id=&#34;signature&#34;&gt;Signature&lt;/h2&gt;&#xA;&lt;div class=&#34;fsdocs-usage&#34;&gt;&#xA;&lt;code&gt;type Scope&lt;/code&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;remarks&#34;&gt;Remarks&lt;/h2&gt;&#xA;&lt;p&gt;Scopes aggregate cleanup in reverse registration order, prevent double-disposal, and surface&#xA;cleanup failures as defects rather than typed business errors.&lt;/p&gt;</description>
    </item>
