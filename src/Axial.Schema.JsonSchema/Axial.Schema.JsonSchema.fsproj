<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net8.0</TargetFrameworks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="'$(TargetFramework)' == 'net8.0'">true</IsAotCompatible>
    <PackageId>Axial.Schema.JsonSchema</PackageId>
    <AssemblyName>Axial.Schema.JsonSchema</AssemblyName>
    <RootNamespace>Axial.Schema</RootNamespace>
    <Authors>Adam Davies</Authors>
    <Description>JSON Schema document generation over Axial.Schema declarations: one schema drives parsing, validation, and the published contract.</Description>
    <PackageProjectUrl>https://github.com/adz/Axial</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/adz/Axial</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageTags>fsharp;schema;jsonschema;openapi;contracts</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <FsDocsCollectionName>Axial</FsDocsCollectionName>
    <FsDocsLogoSource>content/img/axial-inline-light.svg</FsDocsLogoSource>
    <FsDocsLogoAlt>Axial.Schema.JsonSchema</FsDocsLogoAlt>
    <FsDocsLogoLink>https://github.com/adz/Axial</FsDocsLogoLink>
    <FsDocsLicenseLink>https://github.com/adz/Axial/blob/main/LICENSE</FsDocsLicenseLink>
    <FsDocsReleaseNotesLink>https://github.com/adz/Axial/blob/main/RELEASE_NOTES.md</FsDocsReleaseNotesLink>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="JsonSchema.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Axial.Schema\Axial.Schema.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
