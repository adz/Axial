<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net8.0</TargetFrameworks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="'$(TargetFramework)' == 'net8.0'">true</IsAotCompatible>
    <PackageId>Axial.Result</PackageId>
    <AssemblyName>Axial.Result</AssemblyName>
    <RootNamespace>Axial.Result</RootNamespace>
    <Version>0.1.0</Version>
    <Authors>Adam Davies</Authors>
    <Description>Fail-fast Result helpers, checks, and result computation expressions.</Description>
    <PackageProjectUrl>https://github.com/adz/FsFlow</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/adz/FsFlow</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageTags>fsharp;result;check;validation;application</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <FsDocsCollectionName>Axial</FsDocsCollectionName>
    <FsDocsLogoSource>content/img/fsflow-inline-light.svg</FsDocsLogoSource>
    <FsDocsLogoAlt>Axial.Result</FsDocsLogoAlt>
    <FsDocsLogoLink>https://github.com/adz/FsFlow</FsDocsLogoLink>
    <FsDocsLicenseLink>https://github.com/adz/FsFlow/blob/main/LICENSE</FsDocsLicenseLink>
    <FsDocsReleaseNotesLink>https://github.com/adz/FsFlow/blob/main/RELEASE_NOTES.md</FsDocsReleaseNotesLink>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Fable.Core" Version="4.3.0" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Check.fs" />
    <Compile Include="ResultBuilder.fs" />
    <Compile Include="Builders.fs" />
  </ItemGroup>

</Project>
