<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <NoWarn>$(NoWarn);NU1608</NoWarn>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Axial.Schema.Contracts</AssemblyName>
    <RootNamespace>Axial.Schema.Contracts</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Ast.fs" />
    <Compile Include="Parser.fs" />
    <Compile Include="Records.fs" />
    <Compile Include="Resolver.fs" />
    <Compile Include="Emitter.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Compiler.Service" Version="43.12.204" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Axial.Data\Axial.Data.fsproj" />
  </ItemGroup>

</Project>
