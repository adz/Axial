<Project>

  <!--
    [<DeriveSchema>] records are discovered automatically in ordinary F# Compile items.
    Only .contract declarations need a separate MSBuild item:

      <ItemGroup>
        <AxialContract Include="contracts/*.contract" />
      </ItemGroup>

    Generated files go under obj by default and are inserted into F# compilation immediately after
    their declaration file. CheckedIn mode writes sibling .g.fs files but still manages Compile ordering.

    Properties:
      AxialSchemaGenEnabled      - set false to skip generation (default true)
      AxialSchemaNaming          - camel | snake | verbatim (default camel)
      AxialSchemaGeneratedFiles  - Intermediate | CheckedIn (default Intermediate)
      AxialContractNamespace     - namespace for .contract code (required with AxialContract items)
      AxialSchemaGenToolPath     - override the task assembly path
  -->

  <PropertyGroup>
    <AxialSchemaGenEnabled Condition="'$(AxialSchemaGenEnabled)' == ''">true</AxialSchemaGenEnabled>
    <AxialSchemaNaming Condition="'$(AxialSchemaNaming)' == ''">camel</AxialSchemaNaming>
    <AxialSchemaGeneratedFiles Condition="'$(AxialSchemaGeneratedFiles)' == ''">Intermediate</AxialSchemaGeneratedFiles>
    <AxialSchemaGenToolPath Condition="'$(AxialSchemaGenToolPath)' == ''">$(MSBuildThisFileDirectory)../tools/schemagen.dll</AxialSchemaGenToolPath>
  </PropertyGroup>

  <UsingTask TaskName="Axial.Schema.Contracts.Build.GenerateSchemas" AssemblyFile="$(AxialSchemaGenToolPath)" />

  <Target Name="AxialSchemaGen" BeforeTargets="CoreCompile" Condition="'$(AxialSchemaGenEnabled)' == 'true'">
    <GenerateSchemas
      Sources="@(Compile)"
      Contracts="@(AxialContract)"
      CompileItems="@(Compile)"
      Naming="$(AxialSchemaNaming)"
      ContractNamespace="$(AxialContractNamespace)"
      ProjectDirectory="$(MSBuildProjectDirectory)"
      IntermediateOutputPath="$(IntermediateOutputPath)"
      OutputMode="$(AxialSchemaGeneratedFiles)">
      <Output TaskParameter="GeneratedCompileItems" ItemName="_AxialCompile" />
    </GenerateSchemas>

    <ItemGroup>
      <Compile Remove="@(Compile)" />
      <Compile Include="@(_AxialCompile)" />
    </ItemGroup>
  </Target>

</Project>
