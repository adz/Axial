<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Axial.Flow.Telemetry.JavaScript</AssemblyName>
    <RootNamespace>Axial.Flow.Telemetry.JavaScript</RootNamespace>
    <PackageId>Axial.Flow.Telemetry.JavaScript</PackageId>
    <Authors>Adam Davies</Authors>
    <Description>OpenTelemetry JS tracing for Axial flows compiled with Fable: spans, fiber observability, and annotation attributes through a host-supplied @opentelemetry/api object. Node and browser; JavaScript targets only.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/adz/Axial</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageTags>fsharp;axial;flow;telemetry;tracing;opentelemetry;fable;javascript</PackageTags>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Fable.Core" Version="4.3.0" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Axial.Flow\Axial.Flow.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="../Axial.Flow.Telemetry.Shared/SpanConventions.fs" />
    <Compile Include="Telemetry.fs" />
  </ItemGroup>

</Project>
