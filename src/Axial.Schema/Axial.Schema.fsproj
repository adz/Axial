<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net8.0</TargetFrameworks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="'$(TargetFramework)' == 'net8.0'">true</IsAotCompatible>
    <PackageId>Axial.Schema</PackageId>
    <AssemblyName>Axial.Schema</AssemblyName>
    <RootNamespace>Axial.Schema</RootNamespace>
    <Authors>Adam Davies</Authors>
    <Description>Portable model schema definitions for Axial input, validation, codec, documentation, and UI interpreters.</Description>
    <PackageProjectUrl>https://github.com/adz/Axial</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/adz/Axial</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageTags>fsharp;schema;validation;input;metadata</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <FsDocsCollectionName>Axial</FsDocsCollectionName>
    <FsDocsLogoSource>content/img/axial-inline-light.svg</FsDocsLogoSource>
    <FsDocsLogoAlt>Axial.Schema</FsDocsLogoAlt>
    <FsDocsLogoLink>https://github.com/adz/Axial</FsDocsLogoLink>
    <FsDocsLicenseLink>https://github.com/adz/Axial/blob/main/LICENSE</FsDocsLicenseLink>
    <FsDocsReleaseNotesLink>https://github.com/adz/Axial/blob/main/RELEASE_NOTES.md</FsDocsReleaseNotesLink>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Fable.Core" Version="4.3.0" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Axial.ErrorHandling\Axial.ErrorHandling.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="AssemblyInfo.fs" />
    <Compile Include="Platform.fs" />
    <Compile Include="Wire.fs" />
    <Compile Include="SchemaError.fs" />
    <Compile Include="Schema.fs" />
    <Compile Include="RawInput.fs" />
    <Compile Include="SchemaValidation.fs" />
    <Compile Include="ParsedInput.fs" />
    <Compile Include="FieldRef.fs" />
    <Compile Include="ContextRules.fs" />
    <Compile Include="Model.fs" />
    <Compile Include="SchemaApi.fs" />
    <Compile Include="DSL.fs" />
    <Compile Include="Contract.fs" />
    <Compile Include="RefinedSchemas.fs" />
    <Compile Include="Inspection.fs" />
    <Compile Include="JsonSchema.fs" />
  </ItemGroup>

</Project>
