<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net8.0</TargetFrameworks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible Condition="'$(TargetFramework)' == 'net8.0'">true</IsAotCompatible>
    <PackageId>Axial</PackageId>
    <AssemblyName>Axial</AssemblyName>
    <RootNamespace>Axial</RootNamespace>
    <Version>0.1.0</Version>
    <Authors>Adam Davies</Authors>
    <Description>Umbrella package for Axial.Flow, Axial.Result, and Axial.Validation.</Description>
    <PackageProjectUrl>https://github.com/adz/FsFlow</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/adz/FsFlow</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageTags>fsharp;axial;workflow;result;validation;effect</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <FsDocsCollectionName>Axial</FsDocsCollectionName>
    <FsDocsLogoSource>content/img/fsflow-inline-light.svg</FsDocsLogoSource>
    <FsDocsLogoAlt>Axial</FsDocsLogoAlt>
    <FsDocsLogoLink>https://github.com/adz/FsFlow</FsDocsLogoLink>
    <FsDocsLicenseLink>https://github.com/adz/FsFlow/blob/main/LICENSE</FsDocsLicenseLink>
    <FsDocsReleaseNotesLink>https://github.com/adz/FsFlow/blob/main/RELEASE_NOTES.md</FsDocsReleaseNotesLink>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Axial.Flow\Axial.Flow.fsproj" />
    <ProjectReference Include="..\Axial.Result\Axial.Result.fsproj" />
    <ProjectReference Include="..\Axial.Validation\Axial.Validation.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Builders.fs" />
  </ItemGroup>

</Project>
