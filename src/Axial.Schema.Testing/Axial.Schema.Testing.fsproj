<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>Axial.Schema.Testing</AssemblyName>
    <RootNamespace>Axial.Schema.Testing</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="FsCheck" Version="3.3.3" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Axial.Data\Axial.Data.fsproj" />
    <ProjectReference Include="..\Axial.Schema\Axial.Schema.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="SchemaGen.fs" />
  </ItemGroup>
</Project>
