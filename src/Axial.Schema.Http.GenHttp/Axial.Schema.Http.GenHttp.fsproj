<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>Axial.Schema.Http.GenHttp</PackageId>
    <AssemblyName>Axial.Schema.Http.GenHttp</AssemblyName>
    <RootNamespace>Axial.Schema.Http.GenHttp</RootNamespace>
    <Authors>Adam Davies</Authors>
    <Description>GenHTTP hosting for schema-driven Axial Flow endpoints, with trusted request parsing, typed outcome lowering, problem details, compiled codecs, and OpenAPI support.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/adz/Axial</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageTags>fsharp;axial;schema;http;genhttp</PackageTags>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="GenHTTP.Api" Version="10.5.3" />
    <PackageReference Include="GenHTTP.Modules.IO" Version="10.5.3" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Axial.Flow\Axial.Flow.fsproj" />
    <ProjectReference Include="..\Axial.Schema.Http\Axial.Schema.Http.fsproj" />
    <ProjectReference Include="..\Axial.Schema.Codec\Axial.Schema.Codec.fsproj" />
    <ProjectReference Include="..\Axial.Data\Axial.Data.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="GenHttp.fs" />
  </ItemGroup>

</Project>
